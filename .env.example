# Server
PORT=8000

# WhatsApp Business API
# WA_PHONE_ID is REQUIRED for operator replies (POST /send, ADR-004) —
# inbound replies infer the sender from the update, client-initiated sends can't.
WA_PHONE_ID=your_phone_id
WA_TOKEN=your_whatsapp_token
WA_VERIFY_TOKEN=your_custom_verify_token
WA_APP_ID=your_app_id
WA_APP_SECRET=your_app_secret
WA_WABA_ID=your_waba_id
# Dev only (ngrok); in production configure the webhook in Meta Business Suite
# WA_CALLBACK_URL=https://your-ngrok-url.ngrok.io

# Chasqui core
CORE_URL=http://localhost:8090
INTERNAL_API_KEY=

# User-facing fallbacks — English defaults; set them in your users' language.
# (The agent localizes itself via the system prompt; these only fire when the
# core is unreachable or the message type isn't handled.)
# ERROR_REPLY=Sorry, we hit a technical issue. Please try again in a few minutes.
# UNSUPPORTED_REPLY=For now I only handle text, audio, images and buttons. Send me a message and I'll be glad to help.

# Sentry (optional)
SENTRY_DSN=
