# Kamal secrets — copy to .kamal/secrets (gitignored) and fill in.
#   cp .kamal/secrets.example .kamal/secrets
# Docs: https://kamal-deploy.org/docs/commands/secrets/

DOCKER_REGISTRY_PASSWORD=

# --- WhatsApp Business credentials (Meta app) ---
# WA_PHONE_ID is REQUIRED for operator replies (POST /send, ADR-004).
WA_PHONE_ID=
WA_TOKEN=
WA_VERIFY_TOKEN=
WA_APP_ID=
WA_APP_SECRET=
WA_WABA_ID=

# --- Gateway -> core shared secret (SAME value as the core's) ---
INTERNAL_API_KEY=

# --- Sentry (optional — uncomment in config/deploy.yml too) ---
# SENTRY_DSN=
